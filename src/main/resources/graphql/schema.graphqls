type Query {
    order(id: Int!): Order
}

type Mutation {
    createOrder(input: OrderInput!): CreateOrderResponse!
}

type Order {
    id: Int!
    customer: String!
    service: String!
    status: String
    appointmentTime: String!
}

input OrderInput {
    id: Int
    customer: String!
    service: String!
    status: String
    appointmentTime: String!
}

type CreateOrderResponse {
    status: Int!
    message: String!
    order: Order!
}
